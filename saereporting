# ============================================================
#  SERVER
# ============================================================
server <- function(input, output, session) {

  df <- reactive({
    voitures %>%
      filter(
        Fuel_Type          %in% input$f_fuel,
        Transmission       %in% input$f_trans,
        trimws(Owner_Type) %in% input$f_owner,
        Year               >= input$f_year[1],
        Year               <= input$f_year[2],
        Price_eur          >= input$f_price[1],
        Price_eur          <= input$f_price[2]
      )
  })

  # VALUE BOXES
  output$vb_total <- renderValueBox({
    valueBox(format(nrow(df()), big.mark = " "), "Voitures", icon = icon("car"), color = "blue")
  })
  output$vb_prix_moy <- renderValueBox({
    valueBox(paste0(format(round(mean(df()$Price_eur, na.rm=TRUE), 0), big.mark=" "), " EUR"),
             "Prix moyen", icon = icon("euro-sign"), color = "green")
  })
  output$vb_km_moy <- renderValueBox({
    valueBox(paste0(format(round(mean(df()$Kilometers_Driven, na.rm=TRUE)), big.mark=" "), " km"),
             "Kilometrage moyen", icon = icon("road"), color = "orange")
  })
  output$vb_age_moy <- renderValueBox({
    valueBox(paste0(round(mean(2024 - df()$Year, na.rm=TRUE), 1), " ans"),
             "Age moyen", icon = icon("calendar"), color = "purple")
  })

  # ONGLET 3
  output$g_hist_prix <- renderPlot({
    ggplot(df(), aes(x = Price_eur)) +
      geom_histogram(bins=40, fill="#2c7be5", color="white", alpha=0.85) +
      scale_x_continuous(labels = label_number(suffix=" EUR", big.mark=" ")) +
      labs(x="Prix (EUR)", y="Nombre de voitures") + theme_cars()
  })

  output$g_box_fuel <- renderPlot({
    ggplot(df(), aes(x=reorder(Fuel_Type, Price_eur, median), y=Price_eur, fill=Fuel_Type)) +
      geom_boxplot(alpha=0.85, outlier.shape=NA) +
      scale_fill_manual(values=palette_fuel) +
      scale_y_continuous(labels=label_number(suffix=" EUR", big.mark=" "), limits=c(0,50000)) +
      labs(x=NULL, y="Prix (EUR)") + theme_cars() + theme(legend.position="none")
  })

  output$g_pie_fuel <- renderPlot({
    df() %>% count(Fuel_Type) %>%
      mutate(pct = paste0(round(n/sum(n)*100, 1), "%")) %>%
      ggplot(aes(x="", y=n, fill=Fuel_Type)) +
      geom_col(width=1, color="white") +
      geom_text(aes(label=pct), position=position_stack(vjust=0.5),
                color="white", fontface="bold", size=3.5) +
      coord_polar(theta="y") +
      scale_fill_manual(values=palette_fuel) +
      labs(fill=NULL) + theme_void() + theme(legend.position="bottom")
  })

  output$g_bar_trans <- renderPlot({
    df() %>% count(Transmission) %>%
      ggplot(aes(x=Transmission, y=n, fill=Transmission)) +
      geom_col(alpha=0.85, width=0.5) +
      geom_text(aes(label=format(n, big.mark=" ")), vjust=-0.4, fontface="bold") +
      scale_fill_manual(values=c("Manual"="#2c7be5","Automatic"="#e55353")) +
      labs(x=NULL, y="Nombre") + theme_cars() + theme(legend.position="none")
  })

  output$g_bar_owner <- renderPlot({
    df() %>% count(Owner_Type) %>%
      ggplot(aes(x=reorder(Owner_Type,-n), y=n, fill=Owner_Type)) +
      geom_col(alpha=0.85, width=0.5) +
      geom_text(aes(label=format(n, big.mark=" ")), vjust=-0.4, fontface="bold") +
      scale_fill_brewer(palette="Set2") +
      labs(x=NULL, y="Nombre") + theme_cars() + theme(legend.position="none")
  })

  # ONGLET 4
  output$g_line_annee <- renderPlot({
    df() %>% group_by(Year) %>%
      summarise(Prix_Moyen=mean(Price_eur, na.rm=TRUE), n=n(), .groups="drop") %>%
      ggplot(aes(x=Year, y=Prix_Moyen)) +
      geom_line(color="#2c7be5", linewidth=1.3) +
      geom_point(aes(size=n), color="#2c7be5", alpha=0.8) +
      scale_y_continuous(labels=label_number(suffix=" EUR", big.mark=" ")) +
      scale_size_continuous(name="Nb voitures", range=c(2,8)) +
      labs(x="Annee", y="Prix moyen (EUR)") + theme_cars()
  })

  output$g_scatter_km <- renderPlot({
    d_km <- df() %>% filter(Kilometers_Driven < 400000)
    ggplot(d_km, aes(x=Kilometers_Driven, y=Price_eur, color=Fuel_Type)) +
      geom_point(alpha=0.4, size=1.5) +
      geom_smooth(method="lm", se=FALSE, linewidth=1, aes(group=1), color="#1a1a2e") +
      scale_x_continuous(labels=label_number(big.mark=" ", suffix=" km")) +
      scale_y_continuous(labels=label_number(suffix=" EUR", big.mark=" ")) +
      scale_color_manual(values=palette_fuel) +
      labs(x="Kilometrage", y="Prix (EUR)", color="Carburant") + theme_cars()
  })

  output$g_bar_ville <- renderPlot({
    df() %>% group_by(Location) %>%
      summarise(Prix_Moy=mean(Price_eur, na.rm=TRUE), .groups="drop") %>%
      ggplot(aes(x=reorder(Location, Prix_Moy), y=Prix_Moy, fill=Prix_Moy)) +
      geom_col(alpha=0.9) +
      geom_text(aes(label=paste0(format(round(Prix_Moy,0), big.mark=" "), " EUR")),
                hjust=-0.1, size=3.5) +
      scale_fill_gradient(low="#a8d8ea", high="#2c7be5") +
      scale_y_continuous(expand=expansion(mult=c(0,0.2)),
                         labels=label_number(suffix=" EUR", big.mark=" ")) +
      coord_flip() + labs(x=NULL, y="Prix moyen (EUR)") +
      theme_cars() + theme(legend.position="none")
  })

  output$g_scatter_neuf <- renderPlot({
    d <- df() %>% filter(!is.na(NewPrice_eur))
    ggplot(d, aes(x=NewPrice_eur, y=Price_eur, color=Owner_Type)) +
      geom_point(alpha=0.5, size=1.8) +
      geom_abline(slope=1, intercept=0, linetype="dashed", color="grey50") +
      scale_color_brewer(palette="Set1") +
      scale_x_continuous(labels=label_number(suffix=" EUR", big.mark=" ")) +
      scale_y_continuous(labels=label_number(suffix=" EUR", big.mark=" ")) +
      labs(x="Prix neuf (EUR)", y="Prix occasion (EUR)", color="Proprietaire") + theme_cars()
  })

  output$g_box_owner <- renderPlot({
    ggplot(df(), aes(x=Owner_Type, y=Price_eur, fill=Owner_Type)) +
      geom_boxplot(alpha=0.85, outlier.shape=NA) +
      scale_fill_brewer(palette="Set2") +
      scale_y_continuous(labels=label_number(suffix=" EUR", big.mark=" "), limits=c(0,30000)) +
      labs(x=NULL, y="Prix (EUR)") + theme_cars() + theme(legend.position="none")
  })

  # ONGLET 5
  output$g_scatter_power <- renderPlot({
    d <- df() %>% filter(!is.na(Power_num))
    ggplot(d, aes(x=Power_num, y=Price_eur, color=Fuel_Type)) +
      geom_point(alpha=0.4, size=1.5) +
      geom_smooth(method="lm", se=TRUE, aes(group=1), color="#1a1a2e", fill="#1a1a2e", alpha=0.1) +
      scale_color_manual(values=palette_fuel) +
      scale_y_continuous(labels=label_number(suffix=" EUR", big.mark=" ")) +
      labs(x="Puissance (bhp)", y="Prix (EUR)", color="Carburant") + theme_cars()
  })

  output$g_scatter_engine <- renderPlot({
    d <- df() %>% filter(!is.na(Engine_num))
    ggplot(d, aes(x=Engine_num, y=Price_eur, color=Transmission)) +
      geom_point(alpha=0.4, size=1.5) +
      geom_smooth(method="lm", se=TRUE, aes(group=1), color="#1a1a2e", fill="#1a1a2e", alpha=0.1) +
      scale_color_manual(values=c("Manual"="#2c7be5","Automatic"="#e55353")) +
      scale_y_continuous(labels=label_number(suffix=" EUR", big.mark=" ")) +
      labs(x="Cylindree (CC)", y="Prix (EUR)", color="Transmission") + theme_cars()
  })

  output$g_scatter_mileage <- renderPlot({
    d <- df() %>% filter(!is.na(Mileage_num))
    ggplot(d, aes(x=Mileage_num, y=Price_eur, color=Fuel_Type)) +
      geom_point(alpha=0.4, size=1.5) +
      geom_smooth(method="lm", se=TRUE, aes(group=1), color="#1a1a2e", fill="#1a1a2e", alpha=0.1) +
      scale_color_manual(values=palette_fuel) +
      scale_y_continuous(labels=label_number(suffix=" EUR", big.mark=" ")) +
      labs(x="Consommation (kmpl)", y="Prix (EUR)", color="Carburant") + theme_cars()
  })

  output$g_bar_seats <- renderPlot({
    df() %>% filter(!is.na(Seats)) %>% group_by(Seats) %>%
      summarise(Prix_Moy=mean(Price_eur, na.rm=TRUE), n=n(), .groups="drop") %>%
      ggplot(aes(x=factor(Seats), y=Prix_Moy, fill=factor(Seats))) +
      geom_col(alpha=0.85, width=0.6) +
      geom_text(aes(label=paste0(format(round(Prix_Moy,0), big.mark=" "), " EUR\n(n=", n, ")")),
                vjust=-0.3, size=3.2, fontface="bold") +
      scale_fill_brewer(palette="Blues") +
      scale_y_continuous(expand=expansion(mult=c(0,0.2)),
                         labels=label_number(suffix=" EUR", big.mark=" ")) +
      labs(x="Nombre de places", y="Prix moyen (EUR)") +
      theme_cars() + theme(legend.position="none")
  })

  # ONGLET 6 : TABLEAU
  output$tableau <- renderDT({
    df() %>%
      select(Name, Location, Year, Kilometers_Driven, Fuel_Type, Transmission,
             Owner_Type, Mileage_num, Engine_num, Power_num, Seats, Price_eur) %>%
      rename(Modele="Name", Ville="Location", Annee="Year", Kilometrage="Kilometers_Driven",
             Carburant="Fuel_Type", Boite="Transmission", Proprietaire="Owner_Type",
             `Conso (kmpl)`="Mileage_num", `Cylindree (CC)`="Engine_num",
             `Puissance (bhp)`="Power_num", Places="Seats", `Prix (EUR)`="Price_eur") %>%
      datatable(
        extensions = "Buttons",
        options = list(
          dom="Bfrtip",
          buttons=list("copy",
                       list(extend="csv",   filename="voitures"),
                       list(extend="excel", filename="voitures")),
          pageLength=15, scrollX=TRUE,
          language=list(search="Rechercher :", lengthMenu="Afficher _MENU_ lignes",
                        info="Lignes _START_ a _END_ sur _TOTAL_",
                        paginate=list(previous="Precedent", `next`="Suivant"))
        ),
        rownames=FALSE, class="stripe hover compact"
      ) %>%
      formatRound(c("Conso (kmpl)", "Puissance (bhp)"), digits=2) %>%
      formatCurrency("Prix (EUR)", currency="EUR", interval=3, mark=" ", digits=0, before=FALSE) %>%
      formatStyle("Prix (EUR)",
                  background=styleColorBar(range(df()$Price_eur, na.rm=TRUE), "#2c7be5"),
                  backgroundSize="100% 90%", backgroundRepeat="no-repeat",
                  backgroundPosition="center")
  })
}

