# ============================================================
#  CHARGEMENT ET NETTOYAGE
# ============================================================
voitures <- read.csv("~/Desktop/R/BUT2 S4/reporting/data_cars.csv", stringsAsFactors = FALSE)

voitures$Engine_num   <- as.numeric(gsub(" CC", "", voitures$Engine))
voitures$Power_num    <- as.numeric(gsub(" bhp", "", voitures$Power))
voitures$Mileage_num  <- as.numeric(gsub(" kmpl| km/kg", "", voitures$Mileage))
voitures$NewPrice_num <- as.numeric(gsub(" Lakh| Cr", "", voitures$New_Price))

LAKH_TO_EUR <- 1100
voitures$Price_eur    <- round(voitures$Price        * LAKH_TO_EUR, 0)
voitures$NewPrice_eur <- round(voitures$NewPrice_num * LAKH_TO_EUR, 0)

voitures <- voitures %>%
  filter(!is.na(Price), Price > 0, is.na(Seats) | Seats > 0)

fuel_choices  <- sort(unique(voitures$Fuel_Type))
owner_choices <- sort(unique(trimws(voitures$Owner_Type)))
trans_choices <- sort(unique(voitures$Transmission))

# ============================================================
#  THEME & PALETTE
# ============================================================
theme_cars <- function() {
  theme_minimal(base_size = 13) +
    theme(
      plot.background  = element_rect(fill = "transparent", color = NA),
      panel.background = element_rect(fill = "transparent", color = NA),
      panel.grid.major = element_line(color = "#e8e8f0"),
      panel.grid.minor = element_blank(),
      axis.title       = element_text(color = "#555577"),
      legend.position  = "bottom",
      legend.title     = element_text(face = "bold")
    )
}

